# ================= NetBazar Configuration =================
# এই ফাইলটা copy করে .env নামে রাখুন: cp .env.example .env

# ---- Server ----
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000
SITE_NAME=NetBazar

# ---- MongoDB ----
MONGODB_URI=mongodb://127.0.0.1:27017/netbazar

# ---- Security ----
# কমপক্ষে ৩২ ক্যারেক্টারের random string দিন (openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES=12h

# ---- Admin (প্রথম রানে auto-create হবে) ----
ADMIN_EMAIL=admin@netbazar.com
ADMIN_PASSWORD=ChangeMe#2026

# ---- Claude AI Agent (Sonnet 5) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# ---- Uploads ----
# ছবি এখন MongoDB-তে সেভ হয় — redeploy-এ হারায় না, আলাদা ফোল্ডার লাগে না।
# পুরনো ভার্সনের ডিস্কের ছবি DB-তে ঢোকাতে: npm run import-uploads [পুরনো uploads ফোল্ডারের path]

# ---- bKash Tokenized Checkout (PGW) ----
# নোট: এখন Dashboard → পেমেন্ট থেকেও সব gateway (bKash/SSLCommerz/aamarPay/shurjoPay)
# কনফিগার করা যায়। নিচের bKash env গুলো fallback হিসেবে কাজ করে।
# Sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production: https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your-app-key
BKASH_APP_SECRET=your-app-secret
BKASH_USERNAME=your-username
BKASH_PASSWORD=your-password

# ---- Email (Nodemailer + Gmail) ----
# Google-র নতুন নিয়ম: সাধারণ পাসওয়ার্ড চলবে না। App Password লাগবে:
# 1) Google Account → Security → 2-Step Verification অন করুন
# 2) Security → App passwords → নতুন বানান → ১৬ ক্যারেক্টার কপি করুন (স্পেস বাদ)
SMTP_USER=yourshop@gmail.com
SMTP_APP_PASSWORD=abcdabcdabcdabcd
# অর্ডার নোটিফিকেশন কোন ঠিকানায় যাবে (না দিলে SMTP_USER-এই যাবে)
MAIL_ADMIN_TO=

# ---- Business Rules ----
# COD হলে বিকাশে অগ্রিম (টাকা)
COD_ADVANCE_AMOUNT=200
DELIVERY_FEE_INSIDE_DHAKA=70
DELIVERY_FEE_OUTSIDE_DHAKA=130
# এই amount এর উপরে ফ্রি ডেলিভারি (0 = disabled)
FREE_DELIVERY_THRESHOLD=0
